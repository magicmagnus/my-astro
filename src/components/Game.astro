<div class="w-full">
    <iframe
        id="slingshot-frame"
        class="mx-auto aspect-video w-full"
        frameborder="0"
        src="https://slingshot.magnuskaut.de"
        tabindex="0"
        allowfullscreen=""></iframe>

    <div class="mt-4 flex justify-center">
        <button
            id="slingshot-thrust"
            type="button"
            class="shadow-recess touch-none select-none rounded-full bg-paper3 px-5 py-3 font-semibold uppercase text-ink transition hover:scale-105 hover:bg-paper2 focus:outline-none focus:ring-2 focus:ring-ink2 focus:ring-offset-2 active:scale-95"
            aria-label="Hold to thrust"
        >
            Hold to thrust
        </button>
    </div>
</div>

<script is:inline>
    const frame = document.getElementById("slingshot-frame");
    const button = document.getElementById("slingshot-thrust");
    const GAME_ORIGIN = "https://slingshot.magnuskaut.de";

    if (frame && button) {
        let isPressed = false;

        const sendKey = (type) => {
            frame.contentWindow?.postMessage(
                { type: "simulateKey", key: "ArrowUp", eventType: type },
                GAME_ORIGIN,
            );
        };

        const press = (event) => {
            if (isPressed) return;

            event.preventDefault();
            isPressed = true;

            if (button.setPointerCapture && event.pointerId !== undefined) {
                button.setPointerCapture(event.pointerId);
            }

            frame.focus();
            sendKey("keydown");
        };

        const release = (event) => {
            if (!isPressed) return;

            if (event) event.preventDefault();
            isPressed = false;
            sendKey("keyup");

            if (event && button.hasPointerCapture?.(event.pointerId)) {
                button.releasePointerCapture(event.pointerId);
            }
        };

        button.addEventListener("pointerdown", press);
        button.addEventListener("pointerup", release);
        button.addEventListener("pointercancel", release);
        button.addEventListener("lostpointercapture", release);
        button.addEventListener("contextmenu", (event) =>
            event.preventDefault(),
        );

        window.addEventListener("blur", () => {
            if (isPressed) {
                isPressed = false;
                sendKey("keyup");
            }
        });
    }
</script>
