---
interface Props {
    date: Date;
}

const { date } = Astro.props;
---

<time
    datetime={date.toISOString()}
    class="text-xs font-medium tracking-wide text-ink2 md:text-sm lg:text-base"
>
    {
        date.toLocaleDateString("en-us", {
            year: "numeric",
            month: "short",
            day: "numeric",
        })
    }
</time>
