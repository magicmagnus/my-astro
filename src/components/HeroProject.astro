---
import { Icon } from "astro-iconify";

interface Props {
    title: string;
    description: string;
    url: string;
    alingLeft?: boolean;
    scale: number;
    iframeWidth: number;
    iframeHeight: number;
    previewWidth?: number;
    onlyIframe?: boolean;
}

const {
    title,
    description,
    url,
    alingLeft = false,
    scale,
    iframeWidth,
    iframeHeight,
    previewWidth = 420,
    onlyIframe = false,
} = Astro.props;

const iframeOnLeft = alingLeft;
const textAlignClass = iframeOnLeft ? "lg:text-left" : "lg:text-right";
const contentAlignmentClass = iframeOnLeft ? "lg:items-start" : "lg:items-end";
const iframeOrderClass = iframeOnLeft ? "lg:order-0" : "lg:order-1";
const textOrderClass = iframeOnLeft ? "lg:order-1" : "lg:order-0";

const previewStyle = `width: min(100%, ${previewWidth}px); aspect-ratio: ${iframeWidth} / ${iframeHeight};`;
const iframeStyle = `width: ${iframeWidth}px; height: ${iframeHeight}px; transform: scale(${scale}); transform-origin: top left; display: block;`;
---

<article
    class="flex flex-col items-center justify-center gap-4 lg:flex-row lg:gap-10"
>
    <div
        class={iframeOrderClass +
            " shrink-0 overflow-hidden rounded-lg border-2 border-hairline order-0"}
        style={previewStyle}
    >
        <iframe
            src={url}
            title={title}
            width={iframeWidth}
            height={iframeHeight}
            style={iframeStyle}
            data-hero-iframe
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen></iframe>
    </div>

    {
        !onlyIframe && (
            <div
                class={
                    textOrderClass +
                    " flex min-w-0 max-w-md flex-col gap-4 items-start " +
                    contentAlignmentClass +
                    " " +
                    textAlignClass
                }
            >
                <a
                    href={url}
                    target="_blank"
                    class="flex items-center gap-2 text-3xl font-bold lg:text-4xl"
                >
                    <Icon name="radix-icons:arrow-top-right" class="size-8" />
                    {title}
                </a>

                <p class="text-base text-ink2">{description}</p>
            </div>
        )
    }
</article>

<script>
    const IFRAME_HANDOFF_DEBUG = true;

    if (!window.__heroIframeHandoffInit) {
        window.__heroIframeHandoffInit = true;

        const getTrackedIframes = () =>
            Array.from(
                document.querySelectorAll<HTMLIFrameElement>(
                    "iframe[data-hero-iframe]",
                ),
            ).map((iframe) => {
                let origin = "";
                try {
                    origin = new URL(iframe.src, window.location.href).origin;
                } catch {}
                return { iframe, origin };
            });

        if (IFRAME_HANDOFF_DEBUG) {
            console.log("[Parent] handoff init", {
                pageOrigin: window.location.origin,
                tracked: getTrackedIframes().map(({ origin, iframe }) => ({
                    origin,
                    src: iframe.src,
                })),
            });
        }

        window.addEventListener("message", (event) => {
            const data = event.data;

            if (IFRAME_HANDOFF_DEBUG) {
                console.log("[Parent] message received", {
                    origin: event.origin,
                    data,
                });
            }

            if (!data || data.type !== "iframe-scroll-handoff") {
                if (IFRAME_HANDOFF_DEBUG) {
                    console.log("[Parent] ignored: wrong message type");
                }
                return;
            }

            const match = getTrackedIframes().find(
                ({ iframe, origin }) =>
                    iframe.contentWindow === event.source &&
                    origin === event.origin,
            );

            if (!match) {
                if (IFRAME_HANDOFF_DEBUG) {
                    console.warn("[Parent] rejected: origin/source mismatch", {
                        eventOrigin: event.origin,
                        tracked: getTrackedIframes().map(
                            ({ origin, iframe }) => ({
                                origin,
                                src: iframe.src,
                            }),
                        ),
                    });
                }
                return;
            }

            let delta = 0;
            if (
                typeof data.deltaY === "number" &&
                Number.isFinite(data.deltaY)
            ) {
                delta = data.deltaY;
            } else if (data.direction === "down") {
                delta = 120;
            } else if (data.direction === "up") {
                delta = -120;
            }

            delta = Math.max(-220, Math.min(220, delta));
            if (delta === 0) {
                if (IFRAME_HANDOFF_DEBUG) {
                    console.log("[Parent] ignored: delta resolved to 0");
                }
                return;
            }

            if (IFRAME_HANDOFF_DEBUG) {
                console.log("[Parent] scrolling outer page", { delta });
            }

            window.scrollBy({ top: delta, behavior: "auto" });
        });
    }
</script>
