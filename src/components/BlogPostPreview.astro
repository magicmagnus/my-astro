---
import FormattedDate from "./FormattedDate.astro";
import TagLink from "./TagLink.astro";

interface Props {
    title: string;
    description: string;
    heroImage: any;
    slug: string;
    pubDate: Date;
    tags?: string[];
}

const { title, description, heroImage, slug, pubDate, tags } = Astro.props;
---

<div
    class="flex max-w-md flex-col-reverse gap-4 border-b-2 border-hairline pb-5 lg:max-w-full lg:flex-row lg:justify-between lg:pb-8"
>
    <div class="flex flex-col justify-start gap-4">
        <FormattedDate date={pubDate} />
        <a
            class="text-xl font-bold text-ink no-underline transition-transform duration-100 md:text-2xl lg:text-3xl"
            href={`/blog/${slug}`}
        >
            {title}
        </a>

        <ul class="mb-0 mt-auto flex flex-wrap gap-2 gap-y-0">
            {
                tags?.map((tag) => (
                    <li class="m-0 h-fit p-0">
                        <TagLink tag={tag} />
                    </li>
                ))
            }
        </ul>
    </div>
    <a href={`/blog/${slug}`} class="group">
        <div
            class="relative h-60 w-full overflow-hidden rounded-lg bg-paper2 lg:w-96"
        >
            <img
                src={heroImage}
                alt=""
                class="absolute inset-0 h-full w-full scale-110 object-cover blur-md brightness-50"
            />
            <img
                src={heroImage}
                alt=""
                class="absolute inset-0 h-full w-full object-contain transition-transform duration-100 group-hover:scale-105"
            />
        </div>
    </a>
</div>
